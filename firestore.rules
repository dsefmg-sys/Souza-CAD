rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuário só lê/escreve os próprios dados (projetos, cadastros, banco de pontos).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    // Dados compartilhados do credenciado (contadores e pontos)
    match /credenciados/{prefix} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
