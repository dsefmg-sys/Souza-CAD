rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // E-mail do titular (master): vê os perfis de uso e edita a config global do app.
    function ehMaster() {
      return request.auth != null && (
        request.auth.token.email == 'dsefmg@gmail.com'
        || request.auth.token.email.matches('(?i)dsefmg@gmail\\.com')
      );
    }

    // Configuração global do app (ex.: WhatsApp de suporte): todos leem (exceto emailSmtp), só o master escreve.
    match /config/{doc} {
      allow read: if request.auth != null && (doc != 'emailSmtp' || ehMaster());
      allow write: if ehMaster();
    }
    // Credenciais de SMTP pra disparo de e-mail (senha de app do Gmail etc.): documento SEPARADO
    // do config/{doc} geral acima — aqui só o master lê e escreve, nunca os clientes (o config/{doc}
    // geral é de leitura livre pra qualquer autenticado, o que serviria bem pra WhatsApp/URL do app,
    // mas jamais pra uma senha de e-mail). Esta regra, por ser mais específica, tem prioridade sobre
    // a genérica de cima só para este documento.
    match /config/emailSmtp {
      allow read, write: if ehMaster();
    }
    // Segredos do servidor colados pelo master no painel (ex.: chave da IA/Gemini). MESMO motivo do
    // emailSmtp: o config/{doc} geral é de leitura livre pra qualquer autenticado, o que serve pra
    // WhatsApp/URL, mas JAMAIS pra uma chave de API — qualquer cliente logado leria a chave crua e
    // torraria a cota por fora do app. Aqui só o master lê/escreve; o servidor lê pelo Admin SDK,
    // que passa por cima das regras.
    match /config/segredos {
      allow read, write: if ehMaster();
    }

    // Perfil de uso por conta: cada usuário escreve/lê o seu; o master lê E escreve todos (o painel
    // administrativo edita faturamento/CRM de qualquer cliente — sem o master no write, dava
    // "Erro ao salvar dados administrativos"). O dono de um workspace também LÊ (só leitura) o
    // perfil de quem já aceitou o convite dele (resource.data.workspaceUid == meu uid) — é o que
    // permite a tela "Equipe" mostrar quem já está vinculado, não só quem ainda não aceitou.
    match /perfisUso/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid
        || ehMaster()
        // .get(campo, padrão): perfil sem workspaceUid (comum, é opcional) não pode travar
        // a regra com erro de avaliação em vez de simplesmente não bater.
        || (resource != null && resource.data.get('workspaceUid', null) == request.auth.uid)
      );
      // Na CRIAÇÃO, o mesmo cuidado do update: o perfil só nasce com um workspaceUid de terceiro
      // se houver convite válido pra ele. Sem isso, a proteção do update era furada — bastava um
      // perfil novo (conta recém-criada) ou apagar o próprio e recriar apontando pra vítima, e a
      // regra de create antiga (que só checava o uid) deixava passar, dando leitura/escrita nos
      // dados de qualquer um via users/{uid}. Agora create e update guardam o campo do mesmo jeito.
      allow create: if request.auth != null && (
        ehMaster()
        || (
          request.auth.uid == uid
          && (
            request.resource.data.get('workspaceUid', null) == request.auth.uid
            || request.resource.data.get('workspaceUid', null) == null
            || (
              request.auth.token.email != null
              && exists(/databases/$(database)/documents/convites/$(request.auth.token.email))
              && get(/databases/$(database)/documents/convites/$(request.auth.token.email)).data.get('empresaUid', null) == request.resource.data.get('workspaceUid', null)
            )
          )
        )
      );
      allow delete: if request.auth != null && (request.auth.uid == uid || ehMaster());
      // Na atualização (update), o usuário só altera o workspaceUid se estiver voltando para
      // si mesmo (autônomo) ou se houver um convite válido ativo apontando para essa empresa.
      // Isso impede que um usuário force um workspaceUid de terceiros para espionar seus dados.
      allow update: if request.auth != null && (
        ehMaster()
        || (
          request.auth.uid == uid
          && (
            // Não alterou o campo workspaceUid (ou não existia antes e não foi fornecido)
            request.resource.data.get('workspaceUid', null) == resource.data.get('workspaceUid', null)
            // Ou está voltando a usar o próprio workspace (autônomo)
            || request.resource.data.get('workspaceUid', null) == request.auth.uid
            || request.resource.data.get('workspaceUid', null) == null
            // Ou existe um convite pendente para o seu e-mail apontando para esse workspace
            || (
              request.auth.token.email != null
              && exists(/databases/$(database)/documents/convites/$(request.auth.token.email))
              && get(/databases/$(database)/documents/convites/$(request.auth.token.email)).data.get('empresaUid', null) == request.resource.data.get('workspaceUid', null)
            )
          )
        )
      );
    }

    // Convites de workspace (vincular ajudante a uma empresa pelo e-mail exato): id do documento
    // é o e-mail normalizado do convidado. Só o dono da empresa cria (com o próprio uid como
    // empresaUid); só o convidado (pelo próprio e-mail) ou o dono conseguem ler/apagar — ninguém
    // mais enxerga ou adivinha convite de outra empresa.
    match /convites/{email} {
      allow read: if request.auth != null && (
        (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || (resource != null && resource.data.get('empresaUid', null) == request.auth.uid)
        || ehMaster()
      );
      allow create: if request.auth != null && request.resource.data.empresaUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.get('empresaUid', null) == request.auth.uid
        || (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || ehMaster()
      );
      allow update: if false;
    }

    // Solicitação de vínculo (Auxiliar pedindo pra entrar numa empresa): id do documento é o e-mail
    // normalizado de quem PEDE. Substitui o antigo autovínculo instantâneo, que era inseguro —
    // qualquer um digitava o e-mail de um RT e caía dentro dos dados dele sem aprovação. Agora o
    // auxiliar só REGISTRA um pedido; quem entra de fato é decidido pelo dono da empresa, que ao
    // aprovar cria um convite (a única via que libera o workspaceUid, ver regras acima). O dono lê
    // os pedidos endereçados ao PRÓPRIO e-mail (alvoEmail); o solicitante lê/cancela o seu.
    match /solicitacoesVinculo/{email} {
      allow read: if request.auth != null && (
        ehMaster()
        || (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || (resource != null && request.auth.token.email != null
            && string(resource.data.get('alvoEmail', '')).lower() == request.auth.token.email.lower())
      );
      // Só cria o pedido em nome de si mesmo (id == seu e-mail, solicitanteUid == seu uid).
      allow create: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == email
        && request.resource.data.solicitanteUid == request.auth.uid;
      // Apaga: o próprio solicitante (cancelar) ou o dono-alvo (ao aprovar/recusar).
      allow delete: if request.auth != null && (
        ehMaster()
        || (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || (resource != null && request.auth.token.email != null
            && string(resource.data.get('alvoEmail', '')).lower() == request.auth.token.email.lower())
      );
      allow update: if false;
    }

    // Empresa (Etapa 2 do SaaS multi-empresa): id do documento == uid do dono que a criou. Cobrança
    // é POR EMPRESA (compartilhada por todo mundo em `membros`), não mais por pessoa solta.
    match /empresas/{empresaId} {
      allow read: if request.auth != null && (
        ehMaster()
        || empresaId == request.auth.uid
        // .get(campo, padrão) nos dois níveis: nem todo doc tem `membros`, e nem todo `membros`
        // tem a MINHA chave — acesso direto (colchete) trava com erro em vez de negar limpo.
        || (resource != null && resource.data.get('membros', {}).get(request.auth.uid, null) != null)
      );
      // Só o dono cria a própria empresa (id do doc == seu uid) — ou o master, que também pode
      // criar/editar direto pelo painel administrativo (ex.: setar cobrança antes do dono nunca ter
      // logado depois desta etapa existir).
      allow create: if request.auth != null && (
        ehMaster()
        || (empresaId == request.auth.uid && request.resource.data.donoUid == request.auth.uid)
      );
      allow update: if request.auth != null && (
        ehMaster()
        // admin da empresa (dono ou promovido) edita qualquer campo.
        || resource.data.get('membros', {}).get(request.auth.uid, null) == 'admin'
        // qualquer autenticado pode se ADICIONAR como 'membro' — só a própria chave em `membros`,
        // nunca 'admin' nem qualquer outro campo. É o que deixa o convidado/auxiliar se registrar
        // sem precisar de permissão de escrita geral no documento.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membros'])
          && request.resource.data.membros.get(request.auth.uid, null) == 'membro'
          && request.resource.data.membros.diff(resource.data.get('membros', {})).affectedKeys().hasOnly([request.auth.uid])
        )
      );
      allow delete: if ehMaster();
    }

    // Cada usuário só lê/escreve os próprios dados (projetos, cadastros, banco de pontos).
    match /users/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid 
        || ehMaster() 
        || (exists(/databases/$(database)/documents/perfisUso/$(request.auth.uid)) 
            && get(/databases/$(database)/documents/perfisUso/$(request.auth.uid)).data.get('workspaceUid', null) == uid)
      );
      match /{document=**} {
        allow read, write: if request.auth != null && (
          request.auth.uid == uid 
          || ehMaster() 
          || (exists(/databases/$(database)/documents/perfisUso/$(request.auth.uid)) 
              && get(/databases/$(database)/documents/perfisUso/$(request.auth.uid)).data.get('workspaceUid', null) == uid)
        );
      }
    }
    // Dados compartilhados do credenciado (contadores e pontos):
    // apenas o próprio credenciado (uid gravado no documento como _uid) pode ler/escrever.
    match /credenciados/{prefix} {
      allow read: if request.auth != null
        && (resource == null || resource.data.get('_uid', null) == request.auth.uid || ehMaster());
      // Na criação (documento ainda não existe), exige que o uid informado bata com quem escreve.
      allow write: if request.auth != null
        && (ehMaster() || (resource == null
            ? request.resource.data._uid == request.auth.uid
            : resource.data.get('_uid', null) == request.auth.uid));
      match /{document=**} {
        allow read, write: if request.auth != null
          && (ehMaster() || (exists(/databases/$(database)/documents/credenciados/$(prefix))
              ? get(/databases/$(database)/documents/credenciados/$(prefix)).data.get('_uid', null) == request.auth.uid
              : true));
      }
    }
  }
}
