rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // E-mail do titular (master): vê os perfis de uso e edita a config global do app.
    function ehMaster() {
      return request.auth != null && (
        request.auth.token.email == 'dsefmg@gmail.com'
        || request.auth.token.email.matches('(?i)dsefmg@gmail\\.com')
      );
    }

    // Configuração global do app (ex.: WhatsApp de suporte): todos leem, só o master escreve.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if ehMaster();
    }
    // Credenciais de SMTP pra disparo de e-mail (senha de app do Gmail etc.): documento SEPARADO
    // do config/{doc} geral acima — aqui só o master lê e escreve, nunca os clientes (o config/{doc}
    // geral é de leitura livre pra qualquer autenticado, o que serviria bem pra WhatsApp/URL do app,
    // mas jamais pra uma senha de e-mail). Esta regra, por ser mais específica, tem prioridade sobre
    // a genérica de cima só para este documento.
    match /config/emailSmtp {
      allow read, write: if ehMaster();
    }

    // Perfil de uso por conta: cada usuário escreve/lê o seu; o master lê E escreve todos (o painel
    // administrativo edita faturamento/CRM de qualquer cliente — sem o master no write, dava
    // "Erro ao salvar dados administrativos").
    match /perfisUso/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || ehMaster());
      allow write: if request.auth != null && (request.auth.uid == uid || ehMaster());
    }

    // Convites de workspace (vincular ajudante a uma empresa pelo e-mail exato): id do documento
    // é o e-mail normalizado do convidado. Só o dono da empresa cria (com o próprio uid como
    // empresaUid); só o convidado (pelo próprio e-mail) ou o dono conseguem ler/apagar — ninguém
    // mais enxerga ou adivinha convite de outra empresa.
    match /convites/{email} {
      allow read: if request.auth != null && (
        (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || (resource != null && resource.data.empresaUid == request.auth.uid)
        || ehMaster()
      );
      allow create: if request.auth != null && request.resource.data.empresaUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.empresaUid == request.auth.uid
        || (request.auth.token.email != null && request.auth.token.email.lower() == email)
        || ehMaster()
      );
      allow update: if false;
    }

    // Cada usuário só lê/escreve os próprios dados (projetos, cadastros, banco de pontos).
    match /users/{uid} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid 
        || ehMaster() 
        || (exists(/databases/$(database)/documents/perfisUso/$(request.auth.uid)) 
            && get(/databases/$(database)/documents/perfisUso/$(request.auth.uid)).data.workspaceUid == uid)
      );
      match /{document=**} {
        allow read, write: if request.auth != null && (
          request.auth.uid == uid 
          || ehMaster() 
          || (exists(/databases/$(database)/documents/perfisUso/$(request.auth.uid)) 
              && get(/databases/$(database)/documents/perfisUso/$(request.auth.uid)).data.workspaceUid == uid)
        );
      }
    }
    // Dados compartilhados do credenciado (contadores e pontos):
    // apenas o próprio credenciado (uid gravado no documento como _uid) pode ler/escrever.
    match /credenciados/{prefix} {
      allow read: if request.auth != null
        && (resource == null || resource.data._uid == request.auth.uid || ehMaster());
      // Na criação (documento ainda não existe), exige que o uid informado bata com quem escreve.
      allow write: if request.auth != null
        && (ehMaster() || (resource == null
            ? request.resource.data._uid == request.auth.uid
            : resource.data._uid == request.auth.uid));
      match /{document=**} {
        allow read, write: if request.auth != null
          && (ehMaster() || (exists(/databases/$(database)/documents/credenciados/$(prefix))
              ? get(/databases/$(database)/documents/credenciados/$(prefix)).data._uid == request.auth.uid
              : true));
      }
    }
  }
}
