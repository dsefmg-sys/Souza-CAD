rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // E-mail do titular (master): vê os perfis de uso e edita a config global do app.
    function ehMaster() {
      return request.auth != null && request.auth.token.email == 'dsefmg@gmail.com';
    }

    // Configuração global do app (ex.: WhatsApp de suporte): todos leem, só o master escreve.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if ehMaster();
    }

    // Perfil de uso por conta: cada usuário escreve/lê o seu; o master lê E escreve todos (o painel
    // administrativo edita faturamento/CRM de qualquer cliente — sem o master no write, dava
    // "Erro ao salvar dados administrativos").
    match /perfisUso/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || ehMaster());
      allow write: if request.auth != null && (request.auth.uid == uid || ehMaster());
    }

    // Cada usuário só lê/escreve os próprios dados (projetos, cadastros, banco de pontos).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    // Dados compartilhados do credenciado (contadores e pontos):
    // apenas o próprio credenciado (uid gravado no documento como _uid) pode ler/escrever.
    match /credenciados/{prefix} {
      allow read: if request.auth != null
        && (resource == null || resource.data._uid == request.auth.uid);
      // Na criação (documento ainda não existe), exige que o uid informado bata com quem escreve.
      allow write: if request.auth != null
        && (resource == null
            ? request.resource.data._uid == request.auth.uid
            : resource.data._uid == request.auth.uid);
      match /{document=**} {
        allow read, write: if request.auth != null
          && (exists(/databases/$(database)/documents/credenciados/$(prefix))
              ? get(/databases/$(database)/documents/credenciados/$(prefix)).data._uid == request.auth.uid
              : true);
      }
    }
  }
}
