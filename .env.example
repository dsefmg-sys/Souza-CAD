# Souza CAD — variáveis de ambiente
# Copie para .env.local e preencha. Enquanto vazias, o app roda 100% local (IndexedDB).

# --- Firebase (backend de nuvem: projetos/cadastros sincronizados, login) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Deploy num caminho (ex.: /souzacad). Vazio = raiz do (sub)domínio. ---
# Use só se for servir num PATH; para SUBDOMÍNIO (souzacad.souza-solucoes-agro.com.br) deixe vazio.
NEXT_PUBLIC_BASE_PATH=

# --- Chaves SÓ do servidor (sem NEXT_PUBLIC — nunca vão pro navegador) ---
# Google Gemini (IA que lê matrícula/escritura). Gere no Google AI Studio.
GOOGLE_GENAI_API_KEY=
# Pexels (banco de fotos do Estúdio). Gere grátis em pexels.com/api.
PEXELS_API_KEY=
